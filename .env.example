PORT=3100
NODE_ENV=development

# ── Provider selection ─────────────────────────────────────────────────
# Default backend when a request omits `provider`. Routes still accept an
# explicit `provider: "claude" | "codex"` field to override per-call.
DEFAULT_PROVIDER=claude

# ── Claude (Anthropic) CLI ─────────────────────────────────────────────
# Path to the claude CLI binary (default: resolved from PATH)
# CLAUDE_BIN=/home/njakasoa/.local/bin/claude

# Hard timeout for a single claude CLI invocation (ms)
CLAUDE_TIMEOUT_MS=60000

# Default --max-turns argument when caller does not specify
CLAUDE_DEFAULT_MAX_TURNS=1

MAX_CONCURRENT_CLAUDE=3
MAX_QUEUED_CLAUDE=10

# ── Codex (OpenAI) CLI ────────────────────────────────────────────────
# Path to the codex CLI binary (default: resolved from PATH)
# CODEX_BIN=/home/njakasoa/.local/bin/codex

# Hard timeout for a single codex CLI invocation (ms)
CODEX_TIMEOUT_MS=60000

# Symmetry with CLAUDE_DEFAULT_MAX_TURNS; codex has no native --max-turns
# flag so this value is currently ignored at the CLI layer.
CODEX_DEFAULT_MAX_TURNS=1

# Optional model override (uses codex default when unset)
# CODEX_MODEL=gpt-5

# Codex sandbox mode: read-only | workspace-write | danger-full-access
CODEX_SANDBOX=read-only

MAX_CONCURRENT_CODEX=3
MAX_QUEUED_CODEX=10

LOG_LEVEL=info

# Bearer token required on /api/* routes. Leave empty to disable auth (dev only).
# Generate with: openssl rand -hex 32
API_TOKEN=
